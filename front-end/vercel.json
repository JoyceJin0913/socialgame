{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm run build",
  "outputDirectory": "dist/client",
  "framework": null,
  "installCommand": "npm install",
  "functions": {
    "api/[[...all]].mjs": {
      "maxDuration": 60
    }
  },
  "rewrites": [
    {
      "source": "/((?!assets/|prism/|intro/|.*\\.(?:js|css|png|jpg|jpeg|gif|webp|svg|ico|woff|woff2|ttf|map|txt|json|mjs|mp4|webm|mov|m4a|mp3)$).*)",
      "destination": "/api/[[...all]]"
    }
  ]
}
